<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="ir_cron_notificatio_session" model="ir.cron">
        <field name="name">Notification Session Start</field>
        <field name="model_id" ref="model_ahramadhanimodul_session"/>
        <field name="state">code</field>
        <field name="code">model._cron_notification_session_start()</field>
        <field name="active" eval="True"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
    </record>

</odoo>
