<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="category_academy" model="ir.module.category">
        <field name="name">Academy</field>
        <field name="sequence">1</field>
    </record>

    <record id="privilege_academy" model="res.groups.privilege">
        <field name="name">Academy</field>
        <field name="category_id" ref="ahramadhanimodul.category_academy"/>
        <field name="sequence">10</field>
    </record>

    <record id="group_academy_manager" model="res.groups">
        <field name="name">Manager</field>
        <field name="privilege_id" ref="ahramadhanimodul.privilege_academy"/>
    </record>

    <record id="group_academy_user" model="res.groups">
        <field name="name">User</field>
        <field name="privilege_id" ref="ahramadhanimodul.privilege_academy"/>
    </record>

    <record id="responsible_only_can_to_modify" model="ir.rule">
        <field name="name">Only responsible can to modify</field>
        <field name="model_id" ref="ahramadhanimodul.model_ahramadhanimodul_course"/>
        <field name="groups" eval="[(4, ref('ahramadhanimodul.group_academy_manager'))]"/>
        <field name="perm_read" eval="0"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="1" />
        <field name="domain_force">['|',('user_id','=',False),('user_id','=',user.id)]</field>
    </record>

</odoo>
