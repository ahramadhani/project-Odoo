<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="teacher_template" name="Template Teacher">
        <title>Teacher</title>
        <t t-foreach="teachers" t-as="teacher">
            <p>
                <span t-esc="teacher"/>
            </p>
        </t>
    </template>

    <template id="course_template" name="Template Course">
        <t t-call="website.layout">
            <t t-set="title">Course</t>

            <div class="oe_structure">
                <section class="py-5 bg-light">
                    <div class="container">

                        <!-- Header -->
                        <div class="row mb-4">
                            <div class="col-lg-8">
                                <h1 class="fw-bold text-primary">
                                    <i class="fa fa-book me-2"/> Course
                                </h1>
                                <p class="text-muted">
                                    Course data on our academy.
                                </p>
                            </div>

                            <div class="col-lg-4 text-end">
                                <a href="/course/add" class="btn btn-primary btn-lg shadow-sm">
                                    <i class="fa fa-plus-circle me-1"/> Add Course
                                </a>
                            </div>
                        </div>

                        <!-- Card -->
                        <div class="card border-0 shadow-lg rounded-4">
                            <div class="card-body p-4">

                                <div class="table-responsive">
                                    <table class="table table-hover align-middle">
                                        <thead class="table-dark">
                                            <tr>
                                                <th width="5%">#</th>
                                                <th>Course Name</th>
                                                <th>Responsible</th>
                                                <th width="20%" class="text-center">Action</th>
                                            </tr>
                                        </thead>

                                        <tbody>
                                            <t t-if="courses">
                                                <t t-set="no" t-value="1"/>

                                                <tr t-foreach="courses" t-as="course">
                                                    <!-- Number -->
                                                    <td>
                                                        <span class="badge bg-secondary">
                                                            <t t-esc="no"/>
                                                        </span>
                                                    </td>

                                                    <!-- Course Name -->
                                                    <td>
                                                        <a t-attf-href="/course/{{ slug(course) }}"
                                                        class="text-decoration-none fw-bold text-primary">
                                                            <t t-esc="course.name"/>
                                                        </a>
                                                    </td>

                                                    <!-- Responsible -->
                                                    <td>
                                                        <i class="fa fa-user text-muted me-1"/>
                                                        <t t-esc="course.user_id.name"/>
                                                    </td>

                                                    <!-- Action -->
                                                    <td class="text-center">
                                                        <a t-attf-href="/course/edit/{{ slug(course) }}"
                                                        class="btn btn-warning btn-sm rounded-pill px-3 me-1">
                                                            <i class="fa fa-pencil"/> Edit
                                                        </a>

                                                        <a t-attf-href="/course/delete/{{ slug(course) }}"
                                                        class="btn btn-danger btn-sm rounded-pill px-3"
                                                        onclick="return confirm('Are you sure you want to delete this course?');">
                                                            <i class="fa fa-trash"/> Delete
                                                        </a>
                                                    </td>

                                                    <t t-set="no" t-value="no + 1"/>
                                                </tr>
                                            </t>

                                            <!-- Empty Data -->
                                            <t t-if="not courses">
                                                <tr>
                                                    <td colspan="4" class="text-center py-5">
                                                        <img src="/web/static/img/placeholder.png"
                                                            width="120"
                                                            class="mb-3"/>

                                                        <h5 class="text-muted">
                                                            No Course Data Found
                                                        </h5>

                                                        <a href="/course/add"
                                                        class="btn btn-primary mt-2">
                                                            Add First Course
                                                        </a>
                                                    </td>
                                                </tr>
                                            </t>
                                        </tbody>
                                    </table>
                                </div>

                            </div>
                        </div>

                    </div>
                </section>
            </div>
        </t>
    </template>

    <template id="template_course_detail" name="Course Detail">
        <t t-call="website.layout">
            <t t-set="title">Course - <t t-esc="course.name"/></t>

            <div class="oe_structure">
                <section class="py-5 bg-light">
                    <div class="container">

                        <!-- Breadcrumb -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb bg-white shadow-sm px-3 py-2 rounded-3">
                                        <li class="breadcrumb-item">
                                            <a href="/course" class="text-decoration-none">
                                                <i class="fa fa-home me-1"/> Course
                                            </a>
                                        </li>

                                        <li class="breadcrumb-item active text-dark fw-bold"
                                            aria-current="page">
                                            <t t-esc="course.name"/>
                                        </li>
                                    </ol>
                                </nav>
                            </div>
                        </div>

                        <!-- Main Card -->
                        <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                            <!-- Header -->
                            <div class="bg-primary text-white p-5 text-center">
                                <h1 class="fw-bold mb-2">
                                    <i class="fa fa-book-open me-2"/>
                                    <t t-esc="course.name"/>
                                </h1>

                                <p class="mb-1">
                                    <i class="fa fa-user me-1"/>
                                    Responsible :
                                    <strong>
                                        <t t-esc="course.user_id.name"/>
                                    </strong>
                                </p>

                                <p class="mb-0">
                                    <i class="fa fa-align-left me-1"/>
                                    <t t-esc="course.description"/>
                                </p>
                            </div>

                            <!-- Session Table -->
                            <div class="card-body p-4">

                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h4 class="fw-bold text-dark mb-0">
                                        <i class="fa fa-calendar-alt text-primary me-2"/>
                                        Session List
                                    </h4>

                                    <span class="badge bg-primary fs-6 px-3 py-2">
                                        <t t-esc="len(course.session_ids)"/> Sessions
                                    </span>
                                </div>

                                <div class="table-responsive">
                                    <table class="table table-hover align-middle">

                                        <thead class="table-dark">
                                            <tr>
                                                <th width="5%">#</th>
                                                <th>Session</th>
                                                <th>Start Date</th>
                                                <th>Instructor</th>
                                            </tr>
                                        </thead>

                                        <tbody>

                                            <t t-if="course.session_ids">
                                                <t t-set="no" t-value="1"/>

                                                <t t-foreach="course.session_ids" t-as="session">

                                                    <tr>

                                                        <!-- Number -->
                                                        <td>
                                                            <span class="badge bg-secondary">
                                                                <t t-esc="no"/>
                                                            </span>
                                                        </td>

                                                        <!-- Session -->
                                                        <td>
                                                            <span class="fw-semibold text-primary">
                                                               <a t-attf-href="/course/session/{{ slug(session) }}"
                                                                class="fw-semibold text-primary text-decoration-none">
                                                                    <t t-esc="session.name"/>
                                                                </a> 
                                                            </span>
                                                        </td>

                                                        <!-- Start Date -->
                                                        <td>
                                                            <i class="fa fa-calendar text-muted me-1"/>
                                                            <span t-esc="session.start_date.strftime('%d %B %Y')"/>
                                                        </td>

                                                        <!-- Instructor -->
                                                        <td>
                                                            <i class="fa fa-chalkboard-teacher text-muted me-1"/>
                                                            <t t-esc="session.partner_id.name"/>
                                                        </td>

                                                    </tr>

                                                    <t t-set="no" t-value="no + 1"/>

                                                </t>
                                            </t>

                                            <!-- Empty Session -->
                                            <t t-if="not course.session_ids">
                                                <tr>
                                                    <td colspan="4" class="text-center py-5">

                                                        <img src="/web/static/img/placeholder.png"
                                                            width="120"
                                                            class="mb-3"/>

                                                        <h5 class="text-muted">
                                                            No Sessions Available
                                                        </h5>

                                                        <p class="text-muted mb-0">
                                                            This course does not have any sessions yet.
                                                        </p>

                                                    </td>
                                                </tr>
                                            </t>

                                        </tbody>

                                    </table>
                                </div>

                            </div>
                        </div>

                    </div>
                </section>
            </div>

        </t>
    </template>

    <!-- ========================= -->
    <!-- ADD COURSE -->
    <!-- ========================= -->
    <template id="add_course" name="Add Course">
        <t t-call="website.layout">

            <t t-set="title">Add Course</t>

            <section class="py-5 bg-light">
                <div class="container">

                    <!-- Breadcrumb -->
                    <div class="row mb-4">
                        <div class="col-12">
                            <nav aria-label="breadcrumb">
                                <ol class="breadcrumb bg-white shadow-sm px-3 py-2 rounded-4">
                                    <li class="breadcrumb-item">
                                        <a href="/course" class="text-decoration-none">
                                            <i class="fa fa-book me-1"/> Course
                                        </a>
                                    </li>

                                    <li class="breadcrumb-item active fw-bold">
                                        Add Course
                                    </li>
                                </ol>
                            </nav>
                        </div>
                    </div>

                    <!-- Main Card -->
                    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                        <!-- Header -->
                        <div class="bg-primary text-white p-5">
                            <h1 class="fw-bold mb-2">
                                <i class="fa fa-plus-circle me-2"/>
                                Add New Course
                            </h1>

                            <p class="mb-0 opacity-75">
                                Create new course data easily and professionally.
                            </p>
                        </div>

                        <!-- Form -->
                        <div class="card-body p-5">

                            <form method="POST" action="/course/do_add_course">

                                <input type="hidden"
                                    name="csrf_token"
                                    t-att-value="request.csrf_token()"/>

                                <!-- Course Name -->
                                <div class="mb-4">

                                    <label class="form-label fw-bold">
                                        <i class="fa fa-book text-primary me-1"/>
                                        Course Name
                                    </label>

                                    <input type="text"
                                        name="name"
                                        class="form-control form-control-lg rounded-3"
                                        placeholder="Enter Course Name"
                                        required="required"/>

                                </div>

                                <!-- Responsible -->
                                <div class="mb-4">

                                    <label class="form-label fw-bold">
                                        <i class="fa fa-user text-primary me-1"/>
                                        Responsible
                                    </label>

                                    <select class="form-select form-select-lg rounded-3"
                                            name="user_id"
                                            required="required">

                                        <option value="">
                                            Choose Responsible
                                        </option>

                                        <t t-foreach="users" t-as="user">

                                            <option t-att-value="user.id">
                                                <t t-esc="user.name"/>
                                            </option>

                                        </t>

                                    </select>

                                </div>

                                <!-- Description -->
                                <div class="mb-4">

                                    <label class="form-label fw-bold">
                                        <i class="fa fa-align-left text-primary me-1"/>
                                        Description
                                    </label>

                                    <textarea class="form-control rounded-3"
                                            name="description"
                                            rows="5"
                                            placeholder="Write course description here..."/>

                                </div>

                                <!-- Button -->
                                <div class="d-flex justify-content-end">

                                    <a href="/course"
                                    class="btn btn-light border rounded-pill px-4 me-2">
                                        Cancel
                                    </a>

                                    <button type="submit"
                                            class="btn btn-primary rounded-pill px-5 shadow-sm">

                                        <i class="fa fa-save me-1"/>
                                        Save Course

                                    </button>

                                </div>

                            </form>

                        </div>
                    </div>

                </div>
            </section>

        </t>
    </template>


    <!-- ========================= -->
    <!-- EDIT COURSE -->
    <!-- ========================= -->
    <template id="edit_course" name="Edit Course">

        <t t-call="website.layout">

            <t t-set="title">Edit Course</t>

            <section class="py-5 bg-light">

                <div class="container">

                    <!-- Breadcrumb -->
                    <div class="row mb-4">
                        <div class="col-12">

                            <nav aria-label="breadcrumb">

                                <ol class="breadcrumb bg-white shadow-sm px-3 py-2 rounded-4">

                                    <li class="breadcrumb-item">
                                        <a href="/course" class="text-decoration-none">
                                            <i class="fa fa-book me-1"/> Course
                                        </a>
                                    </li>

                                    <li class="breadcrumb-item active fw-bold">
                                        <t t-esc="course.name"/>
                                    </li>

                                </ol>

                            </nav>

                        </div>
                    </div>

                    <!-- Main Card -->
                    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">

                        <!-- Header -->
                        <div class="bg-warning text-dark p-5">

                            <h1 class="fw-bold mb-2">

                                <i class="fa fa-edit me-2"/>
                                Edit Course

                            </h1>

                            <p class="mb-0 opacity-75">
                                Update your course information professionally.
                            </p>

                        </div>

                        <!-- Form -->
                        <div class="card-body p-5">

                            <form method="POST"
                                action="/course/do_edit_course">

                                <input type="hidden"
                                    name="course_id"
                                    t-att-value="course.id"/>

                                <input type="hidden"
                                    name="csrf_token"
                                    t-att-value="request.csrf_token()"/>

                                <!-- Name -->
                                <div class="mb-4">

                                    <label class="form-label fw-bold">

                                        <i class="fa fa-book text-warning me-1"/>
                                        Course Name

                                    </label>

                                    <input type="text"
                                        name="name"
                                        class="form-control form-control-lg rounded-3"
                                        t-attf-value="{{ course.name }}"
                                        placeholder="Enter Course Name"
                                        required="required"/>

                                </div>

                                <!-- Responsible -->
                                <div class="mb-4">

                                    <label class="form-label fw-bold">

                                        <i class="fa fa-user text-warning me-1"/>
                                        Responsible

                                    </label>

                                    <select class="form-select form-select-lg rounded-3"
                                            name="user_id">

                                        <t t-foreach="users" t-as="user">

                                            <option t-att-value="user.id"
                                                    t-att-selected="user.id == course.user_id.id">

                                                <t t-esc="user.name"/>

                                            </option>

                                        </t>

                                    </select>

                                </div>

                                <!-- Description -->
                                <div class="mb-4">

                                    <label class="form-label fw-bold">

                                        <i class="fa fa-align-left text-warning me-1"/>
                                        Description

                                    </label>

                                    <textarea class="form-control rounded-3" name="description" rows="5"><t t-esc="course.description"/></textarea>

                                </div>

                                <!-- Button -->
                                <div class="d-flex justify-content-end">

                                    <a href="/course"
                                    class="btn btn-light border rounded-pill px-4 me-2">

                                        Cancel

                                    </a>

                                    <button type="submit"
                                            class="btn btn-warning rounded-pill px-5 shadow-sm">

                                        <i class="fa fa-save me-1"/>
                                        Update Course

                                    </button>

                                </div>

                            </form>

                        </div>

                    </div>

                </div>

            </section>

        </t>

    </template>

    <!-- ========================= -->
    <!-- session detail -->
    <!-- ========================= -->
        <template id="template_session_detail" name="Session Detail">
            <t t-call="website.layout">
                <t t-set="title">Session - <t t-esc="session.name"/></t>

                <section class="py-5 bg-light">
                    <div class="container">

                        <!-- Breadcrumb -->
                        <div class="row mb-4">
                            <div class="col-12">
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb bg-white shadow-sm px-3 py-2 rounded-4">

                                        <li class="breadcrumb-item">
                                            <a href="/course" class="text-decoration-none">
                                                <i class="fa fa-home me-1"/> Course
                                            </a>
                                        </li>

                                        <li class="breadcrumb-item">
                                            <a t-attf-href="/course/{{ slug(session.course_id) }}"
                                            class="text-decoration-none">
                                                <t t-esc="session.course_id.name"/>
                                            </a>
                                        </li>

                                        <li class="breadcrumb-item active text-dark fw-bold"
                                            aria-current="page">
                                            <t t-esc="session.name"/>
                                        </li>

                                    </ol>
                                </nav>
                            </div>
                        </div>

                        <div class="card shadow-lg border-0 rounded-4">

                            <div class="bg-primary text-white p-4">
                                <h2 class="fw-bold">
                                    <t t-esc="session.name"/>
                                </h2>

                                <p class="mb-0">
                                    Course:
                                    <strong>
                                        <t t-esc="session.course_id.name"/>
                                    </strong>
                                </p>
                            </div>

                            <div class="card-body p-4">

                                <!-- Info Grid -->
                                <div class="row mb-4">

                                    <!-- Left Column -->
                                    <div class="col-md-6">

                                        <p>
                                            <strong>Name:</strong>
                                            <t t-esc="session.name"/>
                                        </p>

                                        <p>
                                            <strong>Instructor:</strong>
                                            <t t-esc="session.partner_id.name"/>
                                        </p>

                                        <p>
                                            <strong>Course:</strong>
                                            <t t-esc="session.course_id.name"/>
                                        </p>

                                        <p>
                                            <strong>Session Code:</strong>
                                            <t t-esc="session.session_code"/>
                                        </p>

                                    </div>

                                    <!-- Right Column -->
                                    <div class="col-md-6">

                                        <p>
                                            <strong>Start Date:</strong>
                                            <span t-esc="session.start_date.strftime('%d %B %Y')"/>
                                        </p>

                                        <p>
                                            <strong>Duration:</strong>
                                            <t t-esc="session.duration"/> days
                                        </p>

                                        <p>
                                            <strong>Number of Seats:</strong>
                                            <t t-esc="session.number_of_seats"/>
                                        </p>

                                        <p class="mb-1">
                                            <strong>Taken Seats:</strong>
                                        </p>
                                        <div class="progress" style="height: 20px;">
                                            <div class="progress-bar bg-primary"
                                                role="progressbar"
                                                t-attf-style="width: {{ session.taken_seats }}%;"
                                                t-attf-aria-valuenow="{{ session.taken_seats }}"
                                                aria-valuemin="0"
                                                aria-valuemax="100">
                                                <t t-esc="'%.0f' % session.taken_seats"/>%
                                            </div>
                                        </div>

                                    </div>

                                </div>

                                <hr/>

                                <!-- Description -->
                                <h5 class="fw-bold text-dark mb-2">
                                    <i class="fa fa-align-left text-primary me-2"/>
                                    Description
                                </h5>
                                <p class="text-muted">
                                    <t t-esc="session.description"/>
                                </p>

                                <hr/>

                                <!-- Attendees -->
                                <div class="d-flex justify-content-between align-items-center mb-3">
                                    <h5 class="fw-bold text-dark mb-0">
                                        <i class="fa fa-users text-primary me-2"/>
                                        Attendees
                                    </h5>

                                    <span class="badge bg-primary fs-6 px-3 py-2">
                                        <t t-esc="len(session.partner_ids)"/> Attendees
                                    </span>
                                </div>

                                <div class="table-responsive">
                                    <table class="table table-hover align-middle">

                                        <thead class="table-dark">
                                            <tr>
                                                <th>Name</th>
                                                <th>Email</th>
                                                <th>Phone</th>
                                            </tr>
                                        </thead>

                                        <tbody>

                                            <t t-if="session.partner_ids">
                                                <t t-foreach="session.partner_ids" t-as="attendee">
                                                    <tr>
                                                        <td>
                                                            <i class="fa fa-user text-muted me-1"/>
                                                            <t t-esc="attendee.name"/>
                                                        </td>
                                                        <td>
                                                            <t t-esc="attendee.email or '-'"/>
                                                        </td>
                                                        <td>
                                                            <t t-esc="attendee.phone or '-'"/>
                                                        </td>
                                                    </tr>
                                                </t>
                                            </t>

                                            <t t-if="not session.partner_ids">
                                                <tr>
                                                    <td colspan="3" class="text-center py-4 text-muted">
                                                        No Attendees Yet
                                                    </td>
                                                </tr>
                                            </t>

                                        </tbody>

                                    </table>
                                </div>

                            </div>

                        </div>

                    </div>
                </section>

            </t>
        </template>
 
</odoo>
