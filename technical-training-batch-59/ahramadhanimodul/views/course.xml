<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ahramadhanimodul.course list view -->
    <record id="ahramadhanimodul.course_view_list" model="ir.ui.view">
        <field name="name">ahramadhanimodul.course.view.list</field>
        <field name="model">ahramadhanimodul.course</field>
        <field name="arch" type="xml">
            <list>
                <!-- Add your fields here -->
                <field name="name"/>
                <field name="user_id"/>
                <field name="description"/>
            </list>
        </field>
    </record>

    <!-- ahramadhanimodul.course form view -->
    <record id="ahramadhanimodul.course_view_form" model="ir.ui.view">
        <field name="name">ahramadhanimodul.course.view.form</field>
        <field name="model">ahramadhanimodul.course</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <!-- Add your fields here -->
                        <field name="name"/>
                        <field name="user_id"/>
                    </group>
                    <notebook>
                        <page string="Description" name="description">
                            <field name="description"/>
                        </page>
                        <page name="session_ids" string="Sessions">
                            <field name="session_ids"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- ahramadhanimodul.course search view -->
    <record id="ahramadhanimodul.course_view_search" model="ir.ui.view">
        <field name="name">ahramadhanimodul.course.view.search</field>
        <field name="model">ahramadhanimodul.course</field>
        <field name="arch" type="xml">
            <search>
                <!-- Add your fields here -->
                <field name="name"/>
                <field name="description" string="Name and description" filter_domain="['|', ('name', 'ilike', self), ('description', 'ilike', self)]"/>

                <filter name="my_course" string="My Course" domain="[('user_id','=', uid)]"/>

                <group>
                    <filter name="group_by_responsible" string="Responsible" context="{'group_by': 'user_id'}"/>
                </group>

            </search>
        </field>
    </record>

    <!-- ahramadhanimodul.course action window -->
    <record id="ahramadhanimodul.course_action" model="ir.actions.act_window">
        <field name="name">Course</field>
        <field name="res_model">ahramadhanimodul.course</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_my_course':1}</field>
    </record>

</odoo>
